      "source": [
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Dataset\n",
        "labels = [\"Python\", \"Java\", \"C++\", \"JavaScript\"]\n",
        "\n",
        "sizes = [40, 30, 20, 10]\n",
        "\n",
        "# Pie chart\n",
        "plt.pie(\n",
        "    sizes,\n",
        "    labels=labels,\n",
        "    autopct='%1.1f%%'\n",
        ")\n",
        "\n",
        "# Title\n",
        "plt.title(\"Pie Chart\")\n",
        "\n",
        "plt.show()"
      ],
