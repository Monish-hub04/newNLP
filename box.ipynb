        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Dataset with outlier\n",
        "marks = [10, 12, 14, 15, 16, 18, 100]\n",
        "\n",
        "# Box plot\n",
        "plt.boxplot(marks)\n",
        "\n",
        "# Labels\n",
        "plt.title(\"Box Plot\")\n",
        "\n",
        "plt.ylabel(\"Marks\")\n",
        "\n",
        "plt.grid()\n",
        "\n",
        "plt.show()"
